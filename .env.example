# Environment Configuration
# Copy this file to .env and adjust values as needed

# Paths
BASE_DIR=/app
DATA_DIR=/app/data
MODELS_DIR=/app/models
CACHE_DIR=/app/cache

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Clustering Configuration
N_CLUSTERS=20

# Cache Configuration
SIMILARITY_THRESHOLD=0.85
CACHE_MAX_SIZE=1000
USE_CLUSTERING=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
